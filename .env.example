# Fraud Rule Engine — local environment example.
# Copy to .env (gitignored) and fill before `docker compose up`.

# Postgres
POSTGRES_USER=fraud
# REQUIRED. Generate locally: openssl rand -base64 24
POSTGRES_PASSWORD=replace-me-with-openssl-rand-base64-24-output
POSTGRES_DB=fraud_engine
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Redpanda (Kafka-compatible)
REDPANDA_PORT=9092
REDPANDA_INTERNAL_PORT=9094
REDPANDA_ADMIN_PORT=9644

# API service
API_PORT=8090  # host-side port; container always listens on 8080. Change if 8090 is taken.
APP_PROFILE=default

# Security — both REQUIRED. The app fails fast at boot if either is missing.
# Generate locally before `docker compose up`:
#   JWT_HS256_SECRET=$(openssl rand -base64 48)
#   SERVICE_API_KEY=$(openssl rand -base64 36)
# Min lengths enforced: JWT >= 32 bytes, API key >= 32 chars.
JWT_HS256_SECRET=replace-me-with-openssl-rand-base64-48-output-min-32-bytes
SERVICE_API_KEY=replace-me-with-openssl-rand-base64-36-output-min-32-chars

# Idempotency / cache
IDEMPOTENCY_TTL_HOURS=24

# Rate limit
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Advisory (optional, --profile advisory)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_TIMEOUT_MS=2000

# Observability (optional, --profile observability)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
OTLP_ENDPOINT=http://otel-collector:4317
